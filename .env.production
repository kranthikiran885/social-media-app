# ============================================================
# SOCIAL MEDIA APP - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=SmartSocialPlatform
APP_VERSION=1.0.0
NODE_ENV=production
LOG_LEVEL=info

# ============================================================
# DATABASE - MONGODB
# ============================================================
MONGO_USERNAME=admin
MONGO_PASSWORD=change_this_strong_password_in_production
MONGO_PORT=27017
MONGO_DB_NAME=smart_social

# ============================================================
# DATABASE - POSTGRESQL
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password_in_production
POSTGRES_DB=smart_social
POSTGRES_PORT=5432

# ============================================================
# CACHE - REDIS
# ============================================================
REDIS_PASSWORD=change_this_strong_password_in_production
REDIS_PORT=6379
REDIS_TTL=3600
REDIS_MAX_RETRIES=3

# ============================================================
# MESSAGE QUEUE - RABBITMQ
# ============================================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=change_this_strong_password_in_production
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# ============================================================
# SEARCH ENGINE - ELASTICSEARCH
# ============================================================
ELASTICSEARCH_PASSWORD=change_this_strong_password_in_production
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http

# ============================================================
# MONITORING - PROMETHEUS & GRAFANA
# ============================================================
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
GRAFANA_PASSWORD=change_this_strong_password_in_production
GRAFANA_PORT=3000

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=change_this_to_a_very_long_random_string_for_production
JWT_REFRESH_SECRET=change_this_to_a_very_long_random_string_for_production
JWT_EXPIRE=24h
REFRESH_TOKEN_EXPIRE=7d
SESSION_SECRET=change_this_to_a_very_long_random_string_for_production

# ============================================================
# AWS CONFIGURATION
# ============================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-social-media-prod
AWS_S3_BUCKET_REGION=us-east-1
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/your-account-id/smart-social

# ============================================================
# FIREBASE (Push Notifications)
# ============================================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=your_firebase_database_url

# ============================================================
# GOOGLE VISION API (Content Moderation)
# ============================================================
GOOGLE_VISION_KEY_PATH=/app/google-vision-key.json

# ============================================================
# OPENAI API (AI Features & Moderation)
# ============================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# ============================================================
# STRIPE (Payments)
# ============================================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================
# EMAIL SERVICE (Nodemailer)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@smartsocial.com
SMTP_FROM_NAME=Smart Social Platform

# ============================================================
# TWILIO (SMS & Phone Verification)
# ============================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# EXTERNAL SERVICES
# ============================================================
AUTH_SERVICE_URL=http://auth-service:3001
CONTENT_SERVICE_URL=http://content-service:3003
FEED_SERVICE_URL=http://feed-service:3004
CHAT_SERVICE_URL=http://chat-service:3002
SEARCH_SERVICE_URL=http://search-service:3006
NOTIFICATION_SERVICE_URL=http://notification-service:3007
ANALYTICS_SERVICE_URL=http://analytics-service:3008
AI_SERVICE_URL=http://ai-moderation-service:3005
PAYMENT_SERVICE_URL=http://payment-service:3009
SECURITY_SERVICE_URL=http://security-service:3010
ADMIN_SERVICE_URL=http://admin-service:3011
ML_SERVICE_URL=http://ml-service:3012
USER_SERVICE_URL=http://user-service:3013
MEDIA_SERVICE_URL=http://media-service:3014
LIVE_SERVICE_URL=http://live-service:3015

# ============================================================
# FRONTEND
# ============================================================
FRONTEND_URL=https://your-domain.com
FRONTEND_PORT=80

# ============================================================
# API GATEWAY
# ============================================================
API_GATEWAY_PORT=8000
API_GATEWAY_HOST=api-gateway
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# CORS & SECURITY
# ============================================================
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://admin.your-domain.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization
CORS_CREDENTIALS=true

# ============================================================
# FILE UPLOAD
# ============================================================
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,mov,avi
UPLOAD_DIR=/uploads
TEMP_DIR=/tmp

# ============================================================
# CDN
# ============================================================
CDN_URL=https://cdn.your-domain.com
CDN_PROVIDER=cloudflare
CDN_ZONE_ID=your_cloudflare_zone_id
CDN_API_KEY=your_cloudflare_api_key

# ============================================================
# BACKUP & DISASTER RECOVERY
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=s3
BACKUP_S3_BUCKET=smart-social-backups

# ============================================================
# LOGGING
# ============================================================
LOG_FORMAT=json
LOG_DIR=/var/log/app
LOG_MAX_FILE_SIZE=10mb
LOG_MAX_FILES=10
SENTRY_DSN=https://your_sentry_dsn

# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_LIVE_STREAMING=true
FEATURE_REELS=true
FEATURE_STORIES=true
FEATURE_SHOPPING=true
FEATURE_PAYMENTS=true
FEATURE_AI_MODERATION=true
FEATURE_VIDEO_CALLS=true

# ============================================================
# PERFORMANCE
# ============================================================
CACHE_ENABLED=true
COMPRESSION_ENABLED=true
CLUSTER_MODE=true
WORKER_THREADS=4
MAX_CONNECTIONS=1000
REQUEST_TIMEOUT=30000
KEEP_ALIVE_TIMEOUT=65000

# ============================================================
# MAINTENANCE
# ============================================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
